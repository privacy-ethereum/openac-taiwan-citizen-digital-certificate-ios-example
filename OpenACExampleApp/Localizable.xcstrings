    "intro.verify_content" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Verification"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "驗證內容"
          }
        }
      }
    },
    "learn_more.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Traditional identity checks may ask you to share full credential data with a website. This flow is different: your browser or device prepares a verifiable result, and the website only receives what it needs for this verification."
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "一般的身份驗證可能需要你把完整證件資料提供給網站。這個流程不同：系統會在你的裝置上確認你是否符合本次要求，並只讓網站取得必要的驗證結果。"
          }
        }
      }
    },
    "learn_more.done" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Got it"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "我知道了"
          }
        }
      }
    },
    "learn_more.nav_title" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "How this technology protects your data"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "這項技術如何保護你的資料？"
          }
        }
      }
    },
    "learn_more.section1.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The website usually only needs to know whether you meet the requirement, not your full identity details."
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "網站通常只需要知道你是否符合這次要求，例如是否具備使用資格，而不需要看到完整身份資料。"
          }
        }
      }
    },
    "learn_more.section1.title" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Only the necessary result"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "只確認必要結果"
          }
        }
      }
    },
    "learn_more.section2.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your credential is used to prepare the verification result, but the website does not need to receive the full certificate contents."
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "你的資料會被用來產生本次驗證所需的結果，但網站不需要取得完整自然人憑證內容。"
          }
        }
      }
    },
    "learn_more.section2.title" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "No full credential sharing"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "不直接分享完整資料"
          }
        }
      }
    },
    "learn_more.section3.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This flow uses OpenAC and zero-knowledge technology to confirm eligibility while reducing unnecessary data disclosure."
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "這個流程使用 OpenAC 與零知識技術，讓系統可以確認資格，同時減少不必要的資料揭露。"
          }
        }
      }
    },
    "learn_more.section3.title" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Privacy-preserving technology"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "使用隱私保護技術"
          }
        }
      }
    },
