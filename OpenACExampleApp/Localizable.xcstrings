        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "What information is shared"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "了解會分享哪些資訊"
          }
