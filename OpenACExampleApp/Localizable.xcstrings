    },
    "intro.privacy_note" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Test Verifier receives the information needed to complete verification to confirm your badge eligibility and update your profile. Full identity data is not shared directly with Test Verifier."
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "測試驗證端會收到完成驗證所需的資訊，用來確認你符合徽章資格並更新你的個人檔案。完整身分資料不會直接提供給測試驗證端。"
          }
        }
      }
    },
    "intro.start" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Start verification"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "開始驗證"
          }
        }
      }
    },
    "intro.title" : {
