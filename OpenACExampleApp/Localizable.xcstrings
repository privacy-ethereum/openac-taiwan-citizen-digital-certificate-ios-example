    "intro.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You will use your Mobile Citizen Digital Certificate to confirm you are a Taiwanese national aged 18 or older. After successful verification, Test Verifier profile will show the Verified Taiwanese Badge."
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "你將使用行動自然人憑證確認自己是年滿 18 歲的台灣人。驗證成功後，測試驗證端個人檔案會顯示台灣人徽章。"
          }
        }
      }
    },
    "intro.condition_value" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
